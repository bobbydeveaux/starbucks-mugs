    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "cheerio": "^1.2.0",
    "eslint": "^9.15.0",
